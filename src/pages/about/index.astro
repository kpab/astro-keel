---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Astro Keel" description="About page for the Astro Keel theme.">
  <section class="page-head section">
    <p class="eyebrow">About</p>
    <h1>Introduce the person or studio behind the work.</h1>
    <p class="lead">
      Use this page for a short profile, current focus, capabilities, and contact context.
      The layout keeps prose comfortable without turning the page into a brochure.
    </p>
  </section>

  <section class="section prose-grid">
    <div>
      <h2>Focus</h2>
      <p>
        Replace this copy with the domain, craft, and constraints that define the work.
        The base theme favors precise paragraphs over oversized panels.
      </p>
    </div>
    <div>
      <h2>Availability</h2>
      <p>
        Add engagement details, collaboration preferences, or a concise contact route.
      </p>
    </div>
  </section>
</BaseLayout>
