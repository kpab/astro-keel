---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b),
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout title="Blog | Astro Keel" description="Blog index for Astro Keel.">
  <section class="page-head section">
    <p class="eyebrow">Blog</p>
    <h1>Notes, essays, and release logs.</h1>
    <p class="lead">
      The blog collection supports tags, descriptions, draft filtering, publish dates,
      and optional hero images.
    </p>
  </section>

  <section class="section content-index" aria-label="Blog posts">
    <div class="index-sidebar">
      <p class="eyebrow">Tags</p>
      <nav class="tag-cloud" aria-label="Blog tags">
        {allTags.map((tag) => <a href={`/blog/tags/${tag}/`}>{tag}</a>)}
      </nav>
    </div>

    <div class="entry-list">
      {
        posts.map((post) => (
          <article class="entry-card">
            <div class="entry-meta">
              <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
              <span>{post.data.tags.join(' / ')}</span>
            </div>
            <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
