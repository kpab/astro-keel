---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Works | Astro Keel" description="Selected work index for Astro Keel.">
  <section class="page-head section">
    <p class="eyebrow">Works</p>
    <h1>Selected projects and case studies.</h1>
    <p class="lead">
      The works collection is typed for descriptions, technology lists, external links,
      repositories, thumbnails, ordering, and publish dates.
    </p>
  </section>

  <section class="section empty-state">
    <p>Add Markdown or MDX entries under <code>src/content/works</code> to populate this page.</p>
  </section>
</BaseLayout>
